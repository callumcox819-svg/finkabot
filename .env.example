BOT_TOKEN=
ADMIN_IDS=
# Локально можно оставить пустым — будет ./bot.db
# Railway: Variable Reference на Postgres → DATABASE_URL (обязательно!)
# DATABASE_URL=postgresql://user:pass@host:5432/railway

VALIDEMAIL_API_KEY_1=
VALIDEMAIL_API_KEY_2=
# Строже отсекать мёртвые адреса (1 по умолчанию). Score без Deliverable не проходит.
# VALIDEMAIL_STRICT=1
# VALIDEMAIL_MIN_SCORE=88
# Тема письма: {{OFFER}} = название объявления
# GLOBAL_SUBJECT_TEMPLATE={{OFFER}}
# Успех рассылки только если письмо в «Отправленных» (меньше ложных «отправлено»)
# MAIL_VERIFY_SENT=1
# Имя в EHLO при подключении к SMTP (по умолчанию — FQDN машины бота, на Railway часто внутреннее).
# Если сравниваете с другим софтом — попробуйте свой нормальный FQDN.
# SMTP_EHLO_HOSTNAME=mail.example.com

GOO_API_BASE=https://api.goo.network
# Общий X-Team-Key команды AQUA (один для всех пользователей бота)
AQUA_TEAM_API_KEY=
# URL картинки по умолчанию для AQUA (если в оффере нет item_photo)
# AQUA_DEFAULT_IMAGE_URL=https://example.com/placeholder.jpg
# Опционально: путь списка профилей (по умолчанию /api/generate/single/profile/list)
# AQUA_PROFILES_LIST_PATH=/api/generate/single/profile/list

DEEPSEEK_API_KEY=
TRANSLATE_PROVIDER=auto
